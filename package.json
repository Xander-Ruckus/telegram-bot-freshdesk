{
  "name": "telegram-bot-freshdesk",
  "version": "1.0.0",
  "description": "Telegram bot that integrates with Freshdesk to push notifications",
  "main": "src/bot.js",
  "bin": "src/bot.js",
  "type": "module",
  "scripts": {
    "start": "node src/bot.js",
    "dev": "nodemon src/bot.js",
    "monitor": "node service-monitor.js",
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "node build.js",
    "build:bundle": "npx esbuild src/bot.js --bundle --platform=node --format=cjs --outfile=dist/bot.bundle.cjs --external:sqlite3",
    "build:exe": "npx pkg dist/bot.bundle.cjs --target node18-win-x64 --output dist/telegram-bot-freshdesk.exe"
  },
  "keywords": [
    "telegram",
    "bot",
    "freshdesk",
    "notifications",
    "webhook"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.2",
    "body-parser": "^1.20.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "sqlite3": "^5.1.7",
    "telegraf": "^4.14.1"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.2",
    "esbuild": "^0.28.0",
    "nodemon": "^3.0.2"
  },
  "pkg": {
    "targets": [
      "node18-win-x64"
    ],
    "scripts": [
      "src/**/*.js",
      "*.js"
    ],
    "assets": [
      "src/**/*",
      "data/**/*",
      ".env*"
    ],
    "outputPath": "dist"
  }
}
